pipeline {
    agent any

    stages {

        stage('Install Python and Pip') {
            steps {
                sh '''
                apt-get update
                apt-get install -y python3 python3-pip
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip3 install --break-system-packages -r lesson_29/requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'PYTHONPATH=. python3 -m pytest lesson_29/tests --alluredir=lesson_29/allure-results'
            }
        }

        stage('Archive Results') {
            steps {
                archiveArtifacts artifacts: 'lesson_29/allure-results/**', fingerprint: true
            }
        }
    }
}